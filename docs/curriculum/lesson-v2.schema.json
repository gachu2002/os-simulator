{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://os-simulator-plan.local/schemas/lesson-v2.schema.json",
  "title": "OSTEP Lesson Schema v2",
  "type": "object",
  "required": ["schema_version", "lesson"],
  "properties": {
    "schema_version": {
      "const": "lesson-v2"
    },
    "lesson": {
      "type": "object",
      "required": [
        "id",
        "title",
        "section_id",
        "difficulty",
        "estimated_minutes",
        "chapter_refs",
        "capability_status",
        "learn",
        "challenge"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "section_id": {
          "enum": [
            "intro",
            "cpu-virtualization",
            "memory-virtualization",
            "concurrency",
            "persistence",
            "distributed",
            "security",
            "capstone"
          ]
        },
        "difficulty": {"enum": ["foundation", "intermediate", "advanced"]},
        "estimated_minutes": {"type": "integer", "minimum": 5},
        "chapter_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "capability_status": {"enum": ["engine-ready", "engine-partial", "theory-only"]},
        "prerequisites": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "learn": {
          "type": "object",
          "required": [
            "core_idea",
            "mechanism_steps",
            "worked_example",
            "common_mistakes",
            "pre_challenge_checklist"
          ],
          "properties": {
            "core_idea": {"type": "string", "minLength": 1},
            "mechanism_steps": {
              "type": "array",
              "minItems": 4,
              "items": {"type": "string", "minLength": 1}
            },
            "worked_example": {"type": "string", "minLength": 1},
            "common_mistakes": {
              "type": "array",
              "minItems": 3,
              "items": {"type": "string", "minLength": 1}
            },
            "pre_challenge_checklist": {
              "type": "array",
              "minItems": 3,
              "items": {"type": "string", "minLength": 1}
            }
          },
          "additionalProperties": false
        },
        "challenge": {
          "type": "object",
          "required": ["objective", "goal", "scenario", "actions", "visualization", "submission", "hints"],
          "properties": {
            "objective": {"type": "string", "minLength": 1},
            "goal": {"type": "string", "minLength": 1},
            "scenario": {
              "type": "object",
              "required": ["seed", "base_config", "bootstrap_commands"],
              "properties": {
                "seed": {"type": "integer", "minimum": 1},
                "base_config": {"type": "object"},
                "bootstrap_commands": {"type": "array", "items": {"type": "object"}}
              },
              "additionalProperties": false
            },
            "actions": {
              "type": "object",
              "required": ["allowed_commands", "action_descriptions", "limits"],
              "properties": {
                "allowed_commands": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "action_descriptions": {"type": "object"},
                "limits": {
                  "type": "object",
                  "required": ["max_steps", "max_policy_changes", "max_config_changes"],
                  "properties": {
                    "max_steps": {"type": "integer", "minimum": 1},
                    "max_policy_changes": {"type": "integer", "minimum": 0},
                    "max_config_changes": {"type": "integer", "minimum": 0}
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            },
            "visualization": {
              "type": "object",
              "required": ["panels", "expected_visual_cues"],
              "properties": {
                "panels": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "expected_visual_cues": {"type": "array", "minItems": 1, "items": {"type": "string"}}
              },
              "additionalProperties": false
            },
            "submission": {
              "type": "object",
              "required": ["pass_rule", "pass_conditions", "validators"],
              "properties": {
                "pass_rule": {"const": "all_required_and_no_forbidden_and_budget_ok"},
                "pass_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
                "validators": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": {"type": "string", "minLength": 1},
                      "type": {
                        "enum": [
                          "trace_contains_all",
                          "trace_order",
                          "trace_count_eq",
                          "trace_count_lte",
                          "no_event",
                          "metric_eq",
                          "metric_lte",
                          "metric_gte",
                          "fault_eq",
                          "fault_lte",
                          "fs_ok",
                          "budget_ok"
                        ]
                      },
                      "key": {"type": "string"},
                      "number": {"type": "number"},
                      "values": {"type": "array", "items": {"type": "string"}},
                      "required": {"type": "boolean"}
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            },
            "hints": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["nudge", "concept", "explicit"],
                "properties": {
                  "nudge": {"type": "string", "minLength": 1},
                  "concept": {"type": "string", "minLength": 1},
                  "explicit": {"type": "string", "minLength": 1}
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
